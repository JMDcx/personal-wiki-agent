# Chat model configuration
FEISHU_RAG_CHAT_API_KEY=your_chat_api_key
FEISHU_RAG_CHAT_BASE_URL=https://your-chat-compatible-endpoint/v1

# Embedding model configuration
FEISHU_RAG_EMBEDDING_API_KEY=your_embedding_api_key
FEISHU_RAG_EMBEDDING_BASE_URL=https://your-embedding-compatible-endpoint/v1

# Optional stage-specific overrides for the multimodal RAG pipeline.
# If unset, these stages fall back to the FEISHU_RAG_* values above.
MULTIMODAL_RAG_CHAT_API_KEY=
MULTIMODAL_RAG_CHAT_BASE_URL=
MULTIMODAL_RAG_EMBEDDING_API_KEY=
MULTIMODAL_RAG_EMBEDDING_BASE_URL=
MULTIMODAL_RAG_VLM_API_KEY=
MULTIMODAL_RAG_VLM_BASE_URL=

# Optional global fallback for both chat and embedding if you prefer shared config
# OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=https://your-compatible-endpoint/v1

# Feishu bot configuration
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_EVENT_MODE=websocket
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_REQUEST_TIMEOUT=20

# Weixin iLink bot configuration
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
# WEIXIN_TOKEN=
WEIXIN_CREDENTIALS_PATH=./data/weixin/credentials.json
WEIXIN_TMP_DIR=./data/weixin/tmp
WEIXIN_REQUEST_TIMEOUT=15
WEIXIN_LONG_POLL_TIMEOUT=35

# Comma-separated Feishu Wiki root node tokens
FEISHU_WIKI_ROOT_TOKENS=wiki_root_token_1,wiki_root_token_2

# Model selection
# FEISHU_RAG_MODEL is used by the main Deep Agent runtime and also acts as the
# fallback model for multimodal RAG stages when no stage-specific override is set.
FEISHU_RAG_MODEL=your_chat_model_name
FEISHU_RAG_EMBEDDING_MODEL=your_embedding_model_name

# Intent classification model.
# Use a private Hugging Face SetFit model in production. For local development,
# FEISHU_INTENT_MODEL_PATH overrides FEISHU_INTENT_MODEL_ID.
FEISHU_INTENT_MODEL_ID=your-org/your-private-intent-model
HF_TOKEN=your_huggingface_token_for_private_model
FEISHU_INTENT_MODEL_PATH=

# Optional stage-specific model overrides for multimodal RAG.
# MULTIMODAL_RAG_CHAT_MODEL: answer generation
# MULTIMODAL_RAG_VLM_MODEL: OCR / caption / image understanding
# MULTIMODAL_RAG_EMBEDDING_MODEL: embedding model used for ingest + retrieval
MULTIMODAL_RAG_CHAT_MODEL=
MULTIMODAL_RAG_VLM_MODEL=
MULTIMODAL_RAG_EMBEDDING_MODEL=

# For Qwen embeddings, keep the exact provider model id lowercase
# (for example: qwen3-embedding-4b)

# Retrieval configuration
FEISHU_RAG_TOP_K=4
FEISHU_RAG_COLLECTION=feishu_wiki_docs

# Local storage
FEISHU_RAG_DATA_DIR=./data
FEISHU_RAG_MANIFEST=index_manifest.json
FEISHU_AGENT_CHECKPOINT_DB_PATH=./data/deepagents/checkpoints.sqlite
FEISHU_LOG_LEVEL=INFO
FEISHU_LOG_CONSOLE_LEVEL=INFO
FEISHU_LOG_JSON_LEVEL=INFO
FEISHU_LOG_FILE_PATH=./data/logs/app.jsonl
FEISHU_LOG_MAX_BYTES=10485760
FEISHU_LOG_BACKUP_COUNT=5
FEISHU_LOG_SERVICE_NAME=feishu_wiki_rag_agent
FEISHU_LOG_INCLUDE_TRACEBACKS=false
FEISHU_LOG_HTTPX_LEVEL=WARNING
FEISHU_LOG_OPENAI_LEVEL=WARNING
FEISHU_LOG_LARK_LEVEL=ERROR
FEISHU_LOG_SUPPRESS_NOISY_LARK_EVENTS=true
FEISHU_LOG_PREVIEW_LENGTH=120
FEISHU_LOG_REDACT_PREVIEWS=false
FEISHU_STREAMING_ENABLED=true
FEISHU_STREAMING_UPDATE_INTERVAL_MS=2500
FEISHU_STREAMING_MAX_CHARS=6000
FEISHU_GROUP_CONCURRENCY_MODE=member
FEISHU_GROUP_MEMORY_RECENT_TURNS=6
FEISHU_DAILY_HISTORY_CLEANUP_ENABLED=true
FEISHU_HISTORY_CLEANUP_CHECK_INTERVAL_SECONDS=3600
BOT_CONCURRENCY_ENABLED=true
BOT_CONCURRENCY_WORKERS=4
BOT_CONCURRENCY_QUEUE_SIZE=8
BOT_CONCURRENCY_PER_THREAD_SERIAL=true

# Knowledge deposit
FEISHU_DEPOSIT_SPACE_ID=
FEISHU_DEPOSIT_PARENT_NODE_TOKEN=
FEISHU_DEPOSIT_WRITE_BACKEND=lark_cli
FEISHU_LARK_CLI_PROFILE=feishu-wiki-rag-agent
DEPOSIT_ENABLE_AUTO_WRITE=true
XHS_MCP_URL=http://127.0.0.1:18060/mcp

MULTIMODAL_RAG_VECTOR_SIZE=4096
