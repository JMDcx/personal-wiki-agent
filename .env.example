# Chat model configuration
FEISHU_RAG_CHAT_API_KEY=your_chat_api_key
FEISHU_RAG_CHAT_BASE_URL=https://your-chat-compatible-endpoint/v1

# Embedding model configuration
FEISHU_RAG_EMBEDDING_API_KEY=your_embedding_api_key
FEISHU_RAG_EMBEDDING_BASE_URL=https://your-embedding-compatible-endpoint/v1

# Optional global fallback for both chat and embedding if you prefer shared config
# OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=https://your-compatible-endpoint/v1

# Feishu bot configuration
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_EVENT_MODE=websocket
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_REQUEST_TIMEOUT=20

# Weixin iLink bot configuration
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
# WEIXIN_TOKEN=
WEIXIN_CREDENTIALS_PATH=./data/weixin/credentials.json
WEIXIN_TMP_DIR=./data/weixin/tmp
WEIXIN_REQUEST_TIMEOUT=15
WEIXIN_LONG_POLL_TIMEOUT=35

# Comma-separated Feishu Wiki root node tokens
FEISHU_WIKI_ROOT_TOKENS=wiki_root_token_1,wiki_root_token_2

# RAG configuration
FEISHU_RAG_MODEL=your_chat_model_name
FEISHU_RAG_EMBEDDING_MODEL=your_embedding_model_name
FEISHU_RAG_TOP_K=4
FEISHU_RAG_COLLECTION=feishu_wiki_docs

# Local storage
FEISHU_RAG_DATA_DIR=./data
FEISHU_RAG_MANIFEST=index_manifest.json
FEISHU_AGENT_CHECKPOINT_DB_PATH=./data/deepagents/checkpoints.sqlite
FEISHU_LOG_LEVEL=INFO
FEISHU_LOG_CONSOLE_LEVEL=INFO
FEISHU_LOG_JSON_LEVEL=INFO
FEISHU_LOG_FILE_PATH=./data/logs/app.jsonl
FEISHU_LOG_MAX_BYTES=10485760
FEISHU_LOG_BACKUP_COUNT=5
FEISHU_LOG_SERVICE_NAME=feishu_wiki_rag_agent
FEISHU_LOG_INCLUDE_TRACEBACKS=false
FEISHU_LOG_HTTPX_LEVEL=WARNING
FEISHU_LOG_OPENAI_LEVEL=WARNING
FEISHU_LOG_LARK_LEVEL=ERROR
FEISHU_LOG_SUPPRESS_NOISY_LARK_EVENTS=true
FEISHU_LOG_PREVIEW_LENGTH=120
FEISHU_LOG_REDACT_PREVIEWS=false

# Knowledge deposit
FEISHU_DEPOSIT_SPACE_ID=
FEISHU_DEPOSIT_PARENT_NODE_TOKEN=
DEPOSIT_ENABLE_AUTO_WRITE=true
XHS_MCP_URL=http://127.0.0.1:18060/mcp

MULTIMODAL_RAG_VECTOR_SIZE=4096
